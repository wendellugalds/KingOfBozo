<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.KingOfBozo" parent="Base.Theme.KingOfBozo.Standard" />

    <style name="CustomAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Theme.KingOfBozo.AlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="materialAlertDialogTitleTextStyle">@style/Theme.KingOfBozo.AlertDialog.Title</item>
        <item name="buttonBarNegativeButtonStyle">@style/Theme.KingOfBozo.AlertDialog.Button</item>
        <item name="buttonBarPositiveButtonStyle">@style/Theme.KingOfBozo.AlertDialog.Button</item>
        <item name="buttonBarNeutralButtonStyle">@style/Theme.KingOfBozo.AlertDialog.Button</item>
    </style>

    <style name="Theme.KingOfBozo.AlertDialog.Title" parent="MaterialAlertDialog.Material3.Title.Text">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Theme.KingOfBozo.AlertDialog.Button" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="backgroundTint">@android:color/transparent</item>
    </style>

    <style name="Base.Theme.KingOfBozo.Standard" parent="Theme.Material3.DayNight.NoActionBar">

        <item name="colorPrimary">@color/padrao</item>

        <item name="textFillColor">@color/text_dark</item>
        <item name="textBackground">@color/text_light</item>

        <item name="icon">@color/icon_dark</item>
        <item name="iconTint">@color/icon_light</item>
        <item name="phoneImage">@drawable/phone_light</item>

        <item name="background">@color/fundo_light</item>
        <item name="cardBackgroundColor">@color/card_light</item>
        <item name="cardForegroundColor">@color/card_dark</item>

        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">true</item>

    </style>



</resources>