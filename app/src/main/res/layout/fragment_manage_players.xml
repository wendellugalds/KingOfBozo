<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background">

    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/buttonBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/textFillColor"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Gerenciar Jogadores"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="?attr/textFillColor"
            android:layout_marginStart="16dp"/>

        <TextView
            android:id="@+id/totalJOGADORESLISTA"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="18sp"
            android:textColor="?attr/textFillColor"
            android:background="@drawable/background_circle"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:gravity="center"/>

    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerInGame"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toBottomOf="parent"
        tools:listitem="@layout/item_manage_player"/>

    <LinearLayout
        android:id="@+id/jogadoresForaJogo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/cardBackgroundColor"
        android:elevation="8dp"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Disponíveis"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="?attr/textFillColor"/>

            <TextView
                android:id="@+id/totalNoJOGADORESLISTA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="?attr/textFillColor"
                android:alpha="0.7"/>

            <ImageView
                android:id="@+id/btnJogarMaisUm"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_person_add"
                app:tint="?attr/textFillColor"
                android:background="@drawable/background_circle"
                android:backgroundTint="?attr/background"/>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNoJogador"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            tools:listitem="@layout/item_manage_player"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>