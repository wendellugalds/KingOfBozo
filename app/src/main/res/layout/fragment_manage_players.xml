<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background">


    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="16dp"
            android:layout_margin="16dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_circle"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                app:tint="?attr/textBackground"
                tools:ignore="ContentDescription" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:orientation="vertical"
                android:layout_weight="1">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GERENCIAR"
                    android:alpha="0.5"
                    android:textColor="?attr/textFillColor"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/total_rodadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JOGADORES"
                    android:textColor="?attr/textFillColor"
                    android:textSize="20dp"
                    android:textStyle="bold" />

            </LinearLayout>

            <Button
                android:id="@+id/btnJogarMaisUm"
                android:layout_width="wrap_content"
                android:layout_height="56dp"
                android:text="NOVO JOGADOR"
                android:textColor="?attr/textBackground"
                app:icon="@drawable/ic_person_add"
                app:iconGravity="textEnd"
                app:iconTint="?attr/textBackground" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:background="@drawable/bottom_sheet_background"
            android:orientation="vertical"
            android:paddingTop="24dp"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:layout_constraintTop_toTopOf="parent">


                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dentro do jogo"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="20dp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Clique no jogador para remover"
                        android:textStyle="bold"
                        android:alpha="0.5"
                        android:textColor="?attr/colorPrimary"
                        android:textSize="15sp" />

                </LinearLayout>

                <TextView
                    android:id="@+id/totalJOGADORESLISTA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="20dp"
                    android:textColor="?attr/textBackground"
                    android:background="@drawable/background_circle"
                    android:backgroundTint="?attr/colorPrimary"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="7dp"
                    android:gravity="center"/>

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerInGame"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingBottom="100dp"
                android:clipToPadding="false"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:listitem="@layout/item_manage_player"/>

        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:id="@+id/jogadoresForaJogo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_background"
        android:backgroundTint="?attr/colorPrimary"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:layout_constraintTop_toTopOf="parent">


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fora do jogo"
                    android:textColor="?attr/textBackground"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"
                    android:text="Clique no jogador para adicionar"
                    android:textColor="?attr/textBackground"
                    android:textSize="15sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <TextView
                android:id="@+id/totalNoJOGADORESLISTA"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/background_circle"
                android:backgroundTint="?attr/cardBackgroundColor"
                android:gravity="center"
                android:paddingHorizontal="15dp"
                android:paddingVertical="7dp"
                android:text="0"
                android:textColor="?attr/colorPrimary"
                android:textSize="20dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerNoJogador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="300dp"
            tools:listitem="@layout/item_manage_player" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>