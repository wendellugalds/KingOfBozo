<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/background">

    <RelativeLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="5dp">

        <FrameLayout
            android:id="@+id/toolbar_container"
            android:layout_width="match_parent"
            android:layout_height="70dp"
            android:layout_alignParentTop="true"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="21dp">

            <LinearLayout
                android:id="@+id/action_bar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:paddingHorizontal="15dp">

                    <TextView
                        android:id="@+id/text_app_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:alpha="0.5"
                        android:text="RANKING"
                        android:textColor="?attr/textFillColor"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/text_title_jogadores"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="25dp"
                        android:text="RODADA"
                        android:textColor="?attr/textFillColor"
                        android:textSize="24sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <Button
                    android:id="@+id/btn_jogar_mais_um"
                    android:layout_width="wrap_content"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:text="JOGAR"
                    android:textColor="?attr/textBackground"
                    app:icon="@drawable/ic_mais_um"
                    app:iconGravity="textEnd"
                    app:iconTint="?attr/textBackground" />

                <ImageView
                    android:id="@+id/btn_sair"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/background_circle"
                    android:backgroundTint="?attr/colorPrimary"
                    android:padding="12dp"
                    android:src="@drawable/ic_door_back"
                    app:tint="?attr/textBackground" />
            </LinearLayout>
        </FrameLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_lista_jogadores_ranking_rodada_final"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/toolbar_container"
            android:paddingBottom="100dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_player_rodada_ranking" />
    </RelativeLayout>

    <!-- Bottom Sheet Persistente -->
    <LinearLayout
        android:id="@+id/persistent_bottom_sheet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_background"
        android:backgroundTint="?attr/colorPrimary"
        android:orientation="vertical"
        android:elevation="16dp"
        app:behavior_peekHeight="95dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior">

        <!-- Header (O que fica visível quando recolhido) -->
        <LinearLayout
            android:id="@+id/card_ranking_geral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="16dp">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginBottom="16dp"
                android:src="@drawable/background_card_dark"
                app:tint="?attr/textBackground" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingBottom="25dp"
                android:paddingHorizontal="30dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RANKING GERAL"
                    android:textColor="?attr/textBackground"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/total_rodadas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 Rodadas"
                    android:background="@drawable/button_background_dark"
                    android:backgroundTint="?attr/cardBackgroundColor"
                    android:paddingVertical="8dp"
                    android:paddingHorizontal="12dp"
                    android:textColor="?attr/textFillColor"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Conteúdo do Ranking Geral -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_view_lista_jogadores_ranking_geral_jogo_atual"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:paddingBottom="30dp"
            android:clipToPadding="false"
            tools:listitem="@layout/item_player_rodada_ranking_geral" />
    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
