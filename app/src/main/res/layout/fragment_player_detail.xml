<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/background"
            android:padding="16dp">

            <LinearLayout
                android:id="@+id/action_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="35dp"
                android:paddingBottom="16dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageView
                    android:id="@+id/button_back"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:background="@drawable/background_circle"
                    android:padding="12dp"
                    android:src="@drawable/ic_arrow_back"
                    app:tint="?attr/textBackground"
                    tools:ignore="ContentDescription" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical"
                    android:layout_weight="1">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="King of Bozó"
                        android:alpha="0.5"
                        android:textColor="?attr/textFillColor"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ranking pessoal"
                        android:textColor="?attr/textFillColor"
                        android:textSize="20dp"
                        android:textStyle="bold" />

                </LinearLayout>

                <ImageView
                    android:id="@+id/button_edit"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:background="@drawable/background_circle_yellow"
                    android:padding="12dp"
                    app:tint="?attr/textBackground"
                    android:src="@drawable/ic_person_edit"
                    tools:ignore="ContentDescription" />

                <ImageView
                    android:id="@+id/button_delete"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:backgroundTint="?attr/colorPrimary"
                    android:background="@drawable/background_circle_yellow"
                    android:padding="12dp"
                    app:tint="?attr/textBackground"
                    android:src="@drawable/ic_delete"
                    android:layout_marginLeft="10dp"
                    tools:ignore="ContentDescription" />

            </LinearLayout>

            <!-- Personal Ranking Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardHaking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="?attr/cardBackgroundColor"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/action_bar">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/text_player_name_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ranking pessoal"
                        android:textColor="?attr/textFillColor"
                        android:textSize="24sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/text_idade"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:alpha="0.5"
                        android:text="Idade"
                        android:textColor="?attr/textFillColor"
                        android:textSize="15sp"
                        app:layout_constraintStart_toStartOf="@+id/text_player_name_detail"
                        app:layout_constraintTop_toBottomOf="@+id/text_player_name_detail" />

                    <FrameLayout
                        android:id="@+id/avatarContainer"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <TextView
                            android:id="@+id/sigla_nome"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/background_circle"
                            android:backgroundTint="?attr/background"
                            android:text="WU"
                            android:textColor="?attr/colorPrimary"
                            android:textStyle="bold"
                            android:textSize="25dp"
                            android:gravity="center" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/imagePlayerAvatarDetail"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@drawable/ic_person"
                            android:visibility="gone"
                            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

                    </FrameLayout>

                    <!-- Arc and Progress visualization -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/arc_container"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="32dp"
                        app:layout_constraintDimensionRatio="H,200:120"
                        app:layout_constraintTop_toBottomOf="@id/text_player_name_detail"
                        app:layout_constraintBottom_toBottomOf="parent">

                        <!-- Actual Arc Vector -->
                        <ImageView
                            android:id="@+id/image_arc"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:src="@drawable/ic_haking_arc" />

                        <!-- Labels -->
                        <TextView
                            android:id="@+id/text_jogadas_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="69"
                            android:textColor="?attr/textFillColor"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            android:layout_marginTop="28dp"
                            android:layout_marginStart="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rodadas"
                            android:textColor="?attr/textFillColor"
                            android:textSize="11sp"
                            android:alpha="0.5"
                            app:layout_constraintStart_toStartOf="@id/text_jogadas_value"
                            app:layout_constraintTop_toBottomOf="@id/text_jogadas_value"
                            android:layout_marginTop="-2dp" />

                        <!-- Badge with crown and wins -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/background_pill_shape"
                            android:backgroundTint="?attr/colorPrimary"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="6dp"
                            android:layout_marginBottom="35dp"
                            app:layout_constraintBottom_toBottomOf="@+id/image_arc"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent">

                            <TextView
                                android:id="@+id/text_ranking_wins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="58"
                                android:drawablePadding="10dp"
                                app:drawableStartCompat="@drawable/ic_crown"
                                app:drawableTint="?attr/textBackground"
                                android:textColor="?attr/textBackground"
                                android:textSize="25sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

            <!-- Statistics Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="?attr/cardBackgroundColor"
                app:cardCornerRadius="32dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardHaking">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/titleStats"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Estatística"
                        android:textColor="?attr/textFillColor"
                        android:textSize="24sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <!-- Progress indicators -->
                    <LinearLayout
                        android:id="@+id/progressContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/titleStats">

                        <LinearLayout
                            android:id="@+id/container_riscos"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:minWidth="60dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_pontos_riscados"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:drawableStartCompat="@drawable/ic_riscar"
                                app:drawableTint="?attr/colorPrimary"
                                android:text="16"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/with_risco"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/background_pill_shape"
                                android:backgroundTint="?attr/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Riscos"
                                android:alpha="0.5"
                                android:textColor="?attr/textFillColor"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <Space
                            android:layout_width="20dp"
                            android:layout_height="match_parent" />

                        <LinearLayout
                            android:id="@+id/container_de_boca"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:minWidth="60dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/text_pontos_boca"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:drawableStartCompat="@drawable/ic_de_boca"
                                app:drawableTint="?attr/colorPrimary"
                                android:text="50"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <View
                                android:id="@+id/with_de_boca"
                                android:layout_width="match_parent"
                                android:layout_height="28dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/background_pill_shape"
                                android:backgroundTint="?attr/colorPrimary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Pontos de boca"
                                android:alpha="0.5"
                                android:textColor="?attr/textFillColor"
                                android:textSize="12sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Bottom Highlight Card -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        app:cardBackgroundColor="?attr/colorPrimary"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:layout_constraintTop_toBottomOf="@id/progressContainer">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pontos"
                                android:textColor="?attr/textBackground"
                                android:textStyle="bold"
                                android:textSize="16sp" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="16dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/text_pontos_acumulados"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Pontos acumulados"
                                    android:textColor="?attr/textBackground"
                                    app:drawableStartCompat="@drawable/ic_score"
                                    app:drawableTint="?attr/textBackground"
                                    android:drawablePadding="10dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center_vertical"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/text_generais"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Generais"
                                    android:textColor="?attr/textBackground"
                                    app:drawableStartCompat="@drawable/ic_general"
                                    app:drawableTint="?attr/textBackground"
                                    android:drawablePadding="10dp" />
                            </LinearLayout>

                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>