<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/numbers_points"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="?attr/background"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        app:tint="?attr/textFillColor"
        android:src="@drawable/background_card_dark" />


    <LinearLayout
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:gravity="center"
        tools:ignore="MissingConstraints">

        <ImageView
            android:id="@+id/button_cancel"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:background="@drawable/background_circle_yellow"
            android:padding="12dp"
            android:layout_marginRight="10dp"
            app:tint="?attr/textFillColor"
            android:src="@drawable/ic_arrow_back"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1"
            app:layout_constraintStart_toEndOf="@+id/button_back">



            <TextView
                android:id="@+id/scoring_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SENA"
                android:textColor="?attr/textFillColor"
                android:textSize="35sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NÚMERO 06"
                android:alpha="0.5"
                android:textColor="?attr/textFillColor"
                android:textSize="16sp" />

        </LinearLayout>

        <ImageView
            android:layout_height="50dp"
            android:layout_width="50dp"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:background="@drawable/background_card_de_boca"
            android:src="@drawable/ic_dice_6"
            app:tint="?attr/colorPrimary"
            android:elevation="2dp"
            android:layout_margin="4dp"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <GridLayout
            xmlns:android="http://schemas.android.com/apk/res/android"
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="3">

            <TextView
                android:id="@+id/valor_01"
                android:layout_height="70dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/textBackground"
                android:text="6"
                android:textSize="35dp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_02"
                android:layout_height="70dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/textBackground"
                android:text="12"
                android:textSize="35dp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_03"
                android:layout_height="70dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/textBackground"
                android:text="18"
                android:textSize="35dp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_04"
                android:layout_height="70dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/textBackground"
                android:text="24"
                android:textSize="35dp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_05"
                android:layout_height="20dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/colorPrimary"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/textBackground"
                android:text="30"
                android:textSize="35dp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <ImageView
                android:id="@+id/btn_nulo"
                android:layout_height="70dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/cardBackgroundColor"
                android:background="@drawable/background_card_black"
                android:src="@drawable/ic_clear"
                app:tint="?attr/colorPrimary"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:padding="20dp"
                android:layout_margin="4dp"/>

            <Button
                android:id="@+id/btn_riscar"
                android:layout_height="70dp"
                android:layout_width="0dp"
                app:backgroundTint="?attr/textFillColor"
                android:background="@drawable/background_score_option_riscar"
                app:cornerRadius="20dp"
                android:text="RISCAR"
                android:textSize="25dp"
                android:textColor="?attr/textFillColor"
                app:icon="@drawable/ic_riscar"
                app:iconSize="25dp"
                app:iconTint="?attr/textFillColor"
                android:gravity="center"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnSpan="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp" />


        </GridLayout>

    </LinearLayout>


</LinearLayout>