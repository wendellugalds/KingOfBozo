<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/form_add_player"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:backgroundTint="?attr/colorPrimary"
    android:background="@drawable/bottom_sheet_background"
    android:orientation="vertical"
    android:paddingTop="16dp">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        app:tint="?attr/textBackground"
        android:src="@drawable/background_card_dark" />



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="30dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RANKING GERAL"
            android:textColor="?attr/textBackground"
            android:textSize="22sp"
            android:layout_weight="1"
            android:textStyle="bold" />
        <TextView
            android:id="@+id/total_rodadas"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10 Rodadas"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:paddingVertical="10dp"
            android:paddingHorizontal="15dp"
            android:background="@drawable/button_background_dark"
            android:textColor="?attr/textFillColor"
            android:textSize="22sp" />

    </LinearLayout>


    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_view_lista_jogadores_ranking_geral_jogo_atual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:itemCount="4"
        android:layout_marginVertical="15dp"
        android:paddingBottom="10dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_player_rodada_ranking_geral" />



</LinearLayout>