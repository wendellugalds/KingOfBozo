<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:backgroundTint="?attr/cardBackgroundColor"
    android:background="@drawable/background_card_2_destaque"
    android:padding="16dp"
    android:layout_margin="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:ignore="MissingConstraints">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/background_circle"
            android:backgroundTint="?attr/background"
            android:padding="12dp"
            android:src="@drawable/ic_game"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/textFillColor"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@+id/button_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Data jogo"
                android:textColor="?attr/textFillColor"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/saved_game_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08/03/2026"
                android:textColor="?attr/textFillColor"
                android:textSize="14sp" />


        </LinearLayout>

        <ImageView
            android:id="@+id/btn_delete"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="10dp"
            android:background="@drawable/background_circle_yellow"
            android:backgroundTint="?attr/background"
            android:padding="12dp"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/colorPrimary"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="20dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginVertical="15dp"
            android:backgroundTint="?attr/background"
            android:gravity="center"
            android:background="@drawable/background_card_game"
            app:layout_constraintStart_toEndOf="@+id/button_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tempo de jogo"
                android:textColor="?attr/textFillColor"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/saved_game_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:10:40"
                android:textStyle="bold"
                android:textColor="?attr/textFillColor"
                android:textSize="20sp" />


        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="20dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="15dp"
            android:orientation="vertical"
            android:layout_marginVertical="15dp"
            android:backgroundTint="?attr/background"
            android:gravity="center"
            android:background="@drawable/background_card_game"
            app:layout_constraintStart_toEndOf="@+id/button_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jogadores"
                android:textColor="?attr/textFillColor"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/saved_game_players"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01"
                android:textStyle="bold"
                android:textColor="?attr/textFillColor"
                android:textSize="20sp" />


        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="10dp"
            android:paddingVertical="20dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginVertical="15dp"
            android:backgroundTint="?attr/background"
            android:gravity="center"
            android:background="@drawable/background_card_game"
            app:layout_constraintStart_toEndOf="@+id/button_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rodadas"
                android:textColor="?attr/textFillColor"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/saved_game_rounds"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01"
                android:textStyle="bold"
                android:textColor="?attr/textFillColor"
                android:textSize="20sp" />


        </LinearLayout>


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        tools:ignore="MissingConstraints"
        android:paddingHorizontal="10dp"
        android:paddingVertical="10dp"
        android:background="@drawable/background_card_game_bottom"
        android:backgroundTint="?attr/background">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/background_circle"
            android:backgroundTint="?attr/cardBackgroundColor"
            android:padding="12dp"
            android:src="@drawable/ic_score"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/textFillColor"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@+id/button_back">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pontos acumulados"
                android:textColor="?attr/textFillColor"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/saved_game_total_score"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08/03/2026"
                android:textColor="?attr/textFillColor"
                android:textSize="14sp" />


        </LinearLayout>

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginLeft="10dp"
            android:background="@drawable/background_circle_yellow"
            android:backgroundTint="?attr/colorPrimary"
            android:padding="12dp"
            android:src="@drawable/ic_entrar"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="?attr/textBackground"
            tools:ignore="ContentDescription" />

    </LinearLayout>
</LinearLayout>
