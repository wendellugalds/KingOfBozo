<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:backgroundTint="?attr/background"
    android:background="?attr/background"
    tools:context=".ui.home.HomeFragment">

    <FrameLayout
        android:id="@+id/text_ajustes_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="15dp"
        android:paddingTop="5dp"
        android:layout_marginTop="36dp"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/text_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:alpha="0.5"
            android:text="@string/king_of_boz"
            android:textColor="?attr/textFillColor"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text_greeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="HOME"
            android:textColor="?attr/textFillColor"
            android:textSize="24sp"
            android:textStyle="bold" />


    </FrameLayout>

    <ImageView
        android:id="@+id/image_logo_fundo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/logo_king_of_boz"
        android:src="@drawable/fundo_logo"
        app:layout_constraintBottom_toTopOf="@+id/button_marcador"
        app:layout_constraintTop_toBottomOf="@+id/text_ajustes_title"
        app:tint="?attr/colorPrimary"
        tools:ignore="MissingConstraints" />

    <ImageView
        android:id="@+id/image_logo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="60dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/logo_king_of_boz"
        android:src="@drawable/logo"
        app:tint="?attr/textBackground"
        app:layout_constraintBottom_toTopOf="@+id/button_marcador"
        app:layout_constraintTop_toBottomOf="@+id/text_ajustes_title"
        tools:layout_editor_absoluteX="60dp" />


    <TextView
        android:id="@+id/button_marcador"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginHorizontal="44dp"
        android:layout_marginBottom="20dp"
        android:background="@drawable/background_card_2_destaque"
        android:backgroundTint="?attr/colorPrimary"
        android:gravity="top|center"
        android:paddingTop="25dp"
        android:text="MARCAR BOZÓ"
        android:textColor="?attr/textBackground"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>