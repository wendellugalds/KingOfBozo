<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="?attr/background">

    <LinearLayout
        android:id="@+id/action_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="16dp"
        android:layout_margin="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/button_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="?attr/colorPrimary"
            android:background="@drawable/background_circle"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="?attr/textBackground"
            tools:ignore="ContentDescription" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:orientation="vertical"
            android:layout_weight="1">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Marcador"
                android:alpha="0.5"
                android:textColor="?attr/textFillColor"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/total_rodadas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RODADA 02"
                android:textColor="?attr/textFillColor"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_jogar_mais_um"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="Ranking"
            android:textColor="?attr/textBackground"
            app:icon="@drawable/ic_ranking"
            app:iconGravity="textStart"
            app:iconTint="?attr/textBackground" />

        <ImageView
            android:id="@+id/button_gerenciar_jogadores"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:backgroundTint="?attr/colorPrimary"
            android:background="@drawable/background_circle_yellow"
            android:padding="12dp"
            app:tint="?attr/textBackground"
            android:src="@drawable/ic_gerenciar_jogador"
            android:layout_marginStart="10dp"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <TextView
        android:id="@+id/pontos_rodada"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:text="0"
        android:gravity="center"
        android:fontFamily="@font/agencyb"
        android:textColor="?attr/textFillColor"
        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="50sp"
        app:autoSizeMaxTextSize="250sp"
        app:layout_constraintTop_toBottomOf="@id/action_bar"
        app:layout_constraintBottom_toTopOf="@id/form_add_player"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/form_add_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_background"
        android:backgroundTint="?attr/colorPrimary"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="25dp"
        android:paddingBottom="130dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_weight="1"
                android:paddingStart="16dp">
                <TextView
                    android:id="@+id/text_player_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nome jogador"
                    android:textColor="?attr/textBackground"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/text_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ganhando"
                    android:alpha="0.6"
                    android:textColor="?attr/textBackground"
                    android:textSize="15sp"
                    android:gravity="center"
                    app:drawableStartCompat="@drawable/ic_crown"
                    app:drawableTint="?attr/textBackground"
                    android:drawablePadding="10dp" />

            </LinearLayout>


            <FrameLayout
                android:id="@+id/avatarContainer"
                android:layout_width="95dp"
                android:layout_height="95dp"
                android:clickable="true"
                android:focusable="true"
                android:padding="15dp"
                android:layout_marginTop="-20dp"
                android:layout_marginEnd="-20dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <ImageView
                    android:id="@+id/icon_king"
                    android:layout_width="37dp"
                    android:layout_height="35dp"
                    android:layout_marginStart="-16dp"
                    android:layout_marginTop="-10dp"
                    android:elevation="1dp"
                    android:importantForAccessibility="no"
                    android:rotation="-45"
                    android:src="@drawable/ic_crown"
                    app:tint="@color/king" />

                <TextView
                    android:id="@+id/sigla_nome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/background_circle"
                    android:backgroundTint="?attr/textBackground"
                    android:text="WU"
                    android:textColor="?attr/colorPrimary"
                    android:textStyle="bold"
                    android:textSize="25sp"
                    android:gravity="center" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imagePlayerAvatarDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_person"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

            </FrameLayout>
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:columnCount="3"
            android:rowCount="4"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/valor_az"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Áz"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="0"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_full"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Full"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="0"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_quadra"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Quadra"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="0"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_duque"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Duque"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="1"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_seguida"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Seguida"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="1"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_quina"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Quina"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="1"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_terno"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Terno"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="2"
                android:layout_column="0"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_quadrada"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Quadrada"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="2"
                android:layout_column="1"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_sena"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="Sena"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="2"
                android:layout_column="2"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

            <TextView
                android:id="@+id/valor_general"
                android:layout_height="65dp"
                android:layout_width="0dp"
                android:backgroundTint="?attr/textBackground"
                android:background="@drawable/background_card_black"
                android:textColor="?attr/colorPrimary"
                android:text="General"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:alpha="0.5"
                android:layout_row="3"
                android:layout_column="0"
                android:layout_columnSpan="3"
                android:layout_columnWeight="1"
                android:layout_gravity="fill"
                android:layout_margin="4dp"/>

        </GridLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/navigation_bar_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bottom_sheet_background"
        android:backgroundTint="?attr/cardBackgroundColor"
        android:orientation="vertical"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:paddingBottom="15dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewJogadoresRodada"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:orientation="horizontal"
            android:paddingTop="35dp"
            tools:listitem="@layout/item_jogador_selection"
            android:clipChildren="false"
            android:clipToPadding="false"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>